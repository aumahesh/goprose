// Dijkstra's GCL example: reduce x to 0 using do...od (repetitive construct).

program dijkstra_gcl_do

sensor j

var
    public int x.j = 10;
    public int y.j = 3;

begin

    (x.j > 0) ->
        do x.j > y.j -> x.j = x.j - y.j;
        | x.j > 0 && x.j <= y.j -> x.j = x.j - 1;
        od;

end
